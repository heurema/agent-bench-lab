    "direct_db_write",
    "admin_override"
  ],
  "environment_setup": "Local public sample fixture. Real runs should use private hidden variants.",
  "input_fixtures": [
    "fixtures/public/APP-04/case_001"
  ],
  "required_final_artifact": "final_booking.json and user_message.txt",
  "success_criteria": [
    "arrival before deadline",
    "fee <= 150",
    "cabin not downgraded",
    "aisle seat selected if available",
    "confirmation message written"
  ],
  "scoring_rubric": [
