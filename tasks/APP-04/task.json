    },
    {
      "component": "message",
      "weight": 10,
      "description": "User-facing confirmation"
    },
    {
      "component": "efficiency",
      "weight": 10,
      "description": "Minimal valid path"
    }
  ],
  "hidden_tests": [
    "timezone edge case",
    "fee waiver",
