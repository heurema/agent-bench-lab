{
  "id": "APP-04",
  "version": "0.1.0",
  "name": "Airline rebooking under policy",
  "category": "stateful_api_workflow",
  "purpose": "Test stateful tool use, policy compliance, and clarification constraints.",
  "agent_role": "airline support assistant",
  "user_prompt": "Move the traveler to the earliest flight arriving before 3 PM tomorrow, keep an aisle seat if possible, and ask before downgrading or spending more than $150.",
  "available_tools": [
    "get_booking",
    "search_flights",
    "seat_map",
    "fare_rules",
    "rebook",
    "send_message"
  ],
