        "text": "Duplicate ids ignored: E-2002"
      },
      {
        "metric": "null_revenue_event_count",
        "text": "Null revenue events: 1"
      },
      {
        "metric": "boundary_event_count",
        "text": "Boundary events included: 2"
      },
      {
        "metric": "total_revenue_usd",
        "text": "Total revenue: 450.00"
      },
      {
        "metric": "top_region_by_revenue",
        "text": "Top region: EU"
      }
