{
  "case_id": "case_002",
  "description": "Synthetic DATA-01 case covering duplicate event ids, null revenue, inclusive date boundaries, and category normalization.",
  "required_artifacts": [
    "metrics.json",
    "report.md",
    "chart_spec.json"
  ],
  "allow_extra_files": false,
  "score_caps": {
